# Copy this file to .env.local and fill in real values.

# Neon Postgres — pooled connection (for app queries)
DATABASE_URL=
# Neon Postgres — unpooled connection (for migrations / drizzle-kit)
DATABASE_URL_UNPOOLED=

# NextAuth (Auth.js v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Resend — for magic-link emails
RESEND_API_KEY=
EMAIL_FROM="Faircutter <onboarding@resend.dev>"

# Stripe — leave blank until Step 9. PAYWALL_ENABLED stays false at launch.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FAIR_MONTHLY=
STRIPE_PRICE_TRIP_PASS=
PAYWALL_ENABLED=false

# Cloudflare — for DNS automation, R2, etc. Optional at launch.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# Telemetry — optional, Steps 10-11
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
